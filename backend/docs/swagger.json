{
    "swagger": "2.0",
    "info": {
        "description": "API для загрузки PDF и получения ZIP с изображениями",
        "title": "PDF Image Extractor API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/jobs": {
            "post": {
                "description": "Создает новую задачу и возвращает presigned URL для загрузки PDF в MinIO",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jobs"
                ],
                "summary": "Инициализировать загрузку PDF",
                "responses": {
                    "201": {
                        "description": "Данные для загрузки",
                        "schema": {
                            "$ref": "#/definitions/handler.InitUploadResponse"
                        }
                    },
                    "405": {
                        "description": "Метод не разрешен",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/jobs/{job_id}/complete-upload": {
            "post": {
                "description": "Отмечает задачу как готовую к обработке после успешной загрузки PDF",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "jobs"
                ],
                "summary": "Завершить загрузку PDF",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID задачи",
                        "name": "job_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Статус успешно обновлен",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Некорректный путь или ID",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    },
                    "405": {
                        "description": "Метод не разрешен",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/handler.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/pdf": {
            "post": {
                "description": "Принимает PDF файл и сохраняет его для обработки",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "pdf"
                ],
                "summary": "Загрузить PDF",
                "parameters": [
                    {
                        "type": "file",
                        "description": "PDF файл",
                        "name": "pdf",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "PDF успешно загружен"
                    },
                    "400": {
                        "description": "Некорректный запрос",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Ошибка сервера",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/zip": {
            "get": {
                "description": "Возвращает ZIP архив с изображениями из PDF",
                "produces": [
                    "application/zip"
                ],
                "tags": [
                    "zip"
                ],
                "summary": "Скачать ZIP с изображениями",
                "responses": {
                    "200": {
                        "description": "ZIP архив",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "500": {
                        "description": "Ошибка сервера",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handler.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        },
        "handler.InitUploadResponse": {
            "type": "object",
            "properties": {
                "job_id": {
                    "type": "string"
                },
                "pdf_key": {
                    "type": "string"
                },
                "presigned_url": {
                    "type": "string"
                }
            }
        }
    }
}